# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
VITE_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
# Dev/test: use hCaptcha test sitekey 10000000-ffff-ffff-ffff-000000000001
# (pairs with secret 0x0000000000000000000000000000000000000000 in Supabase dashboard)

# Docusaurus documentation site (deployed separately on Vercel).
# Used by the sidebar "Docs & Updates" link and the navbar docs shortcut.
# Leave blank to hide the docs nav entries entirely.
VITE_DOCS_URL=https://docs.linetec.app

# Sentry Error Monitoring (optional)
VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=   # Defaults to Vite MODE
# VITE_SENTRY_RELEASE=       # Set by CI/hosting provider

# Mock mode — set to "true" to use local mock data instead of live API calls.
# Always false in production. Access in code via: import.meta.env.VITE_USE_MOCK === 'true'
# WARNING: never use bare `USE_MOCK` — Vite only injects VITE_* env vars via import.meta.env.
VITE_USE_MOCK=false
