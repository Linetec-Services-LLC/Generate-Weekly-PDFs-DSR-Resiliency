# Environment variables (contains sensitive API keys)
.env
.env.local
.env.production
.env.staging

# Portal-specific environment files
portal/.env
portal/.env.local
portal/.env.production
portal/.env.staging
portal/.env.*.local

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
temp/

# AI model files (can be large)
ai_models/
*.h5
*.pkl
*.joblib

# Generated artifacts & caches (kept out of VCS)
generated_docs/*.xlsx
generated_docs/audit_state.json
generated_docs/discovery_cache.json
generated_docs/risk_trend.json
generated_docs/run_summary.json
!generated_docs/README.md

# Notion integration local config (contains database IDs)
scripts/notion_config.json

# Backup files
*.bak
*.backup

# Excel files with potentially sensitive data (keep local only)
*.xlsx
!template*.xlsx

# Coverage reports
coverage.xml
.coverage
htmlcov/
.pytest_cache/

generated_docs/hash_history.json

# Portal dependencies
portal/node_modules/

# portal-v2: un-ignore src/lib/ (overrides Python lib/ pattern above)
!portal-v2/src/lib/
!portal-v2/src/lib/**
# portal: un-ignore lib/ (overrides Python lib/ pattern above)
!portal/lib/
!portal/lib/**

# Local artifact inspection (downloaded GHA artifacts for debugging — never committed)
_inspect_artifact/
artifact_inspection/

# ── Secrets / local env (defense-in-depth; .env.example IS committed) ──
# Catch any .env.<suffix> not already listed above, but keep the examples.
.env.*
!.env.example
!portal/.env.example
!portal-v2/.env.example
# Generic local-only override files (e.g. *.local, CLAUDE.local.md).
*.local
CLAUDE.local.md

# ── Claude Code / AI tooling local-only files (machine-specific) ──
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/session-delta.jsonl
.claude/writeback-pending/*.md
!.claude/writeback-pending/README.md

# ── Node dependencies (top-level; portal*/node_modules handled above) ──
node_modules/

# ── Build output ──
dist/
